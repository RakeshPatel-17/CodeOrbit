{
  "name": "bun-react-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "build": "bun build ./src/index.html --outdir=dist --sourcemap --target=browser --minify --env=inline",
    "start": "NODE_ENV=production bun src/index.ts"
  },
  "dependencies": {
    "@clerk/clerk-react": "^5.61.3",
    "@elysiajs/cors": "^1.4.2",
    "elysia": "^1.4.28",
    "react": "^19",
    "react-dom": "^19"
  },
  "devDependencies": {
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/bun": "latest"
  }
}
